# ── Local AI Structify — Environment Variables ─────────────────────────
# Copy this file to .env and adjust values for your environment.
#   cp .env.example .env
# ────────────────────────────────────────────────────────────────────────

# ── Ollama (LLM Inference) ────────────────────────────────────────────
# URL of the Ollama API server.
#   - Local / bare-metal: http://localhost:11434
#   - Docker Compose:     http://ollama:11434
OLLAMA_BASE_URL=http://localhost:11434

# ── LoRA / Fine-tuned adapters ────────────────────────────────────────
# Path to a safetensors LoRA adapter (optional).
LORA_ADAPTER_PATH=

# ── Streamlit Server ──────────────────────────────────────────────────
# Set to 0.0.0.0 inside Docker so nginx can reach the app.
STREAMLIT_SERVER_ADDRESS=0.0.0.0
STREAMLIT_SERVER_PORT=8501
STREAMLIT_SERVER_HEADLESS=true

# ── Data Directories (defaults — override if needed) ─────────────────
DATABASE_URL=sqlite:///data/local_ai.db
UPLOADS_DIR=./uploads
CACHE_DIR=./cache
DATA_DIR=./data
MODELS_DIR=./models
LOGS_DIR=./logs

# ── Docker Deployment (optional) ─────────────────────────────────────
# Set to current user's UID:GID for volume permission mapping.
# Find yours with:  id -u  (uid)   and   id -g  (gid)
# DOCKER_UID=1000
# DOCKER_GID=1000
