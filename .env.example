# ── Local AI Structify ────────────────────────────────────────────────
# Copy this file to .env and fill in your overrides.
#
# Everything has a sensible default — only set what you need to override.
# ────────────────────────────────────────────────────────────────────────

# Path overrides (supports relative paths)
# PROJECT_ROOT=
# ASSETS_DIR=
# UPLOADS_DIR=
# CACHE_DIR=
# DATA_DIR=
# MODELS_DIR=
# LOGS_DIR=

# Database
# DATABASE_URL=sqlite:///data/local_ai.db
# DATABASE_ECHO=false

# File uploads
# MAX_UPLOAD_SIZE_MB=500

# OCR (Tesseract)
# OCR_LANGUAGE=eng
# OCR_DPI=300
# TESSERACT_CMD=tesseract

# Whisper (faster-whisper)
# WHISPER_MODEL_DIR=models/whisper/base
# WHISPER_LANGUAGE=en
# WHISPER_DEVICE=cpu
# WHISPER_THREADS=4
# WHISPER_TASK=transcribe
# WHISPER_BEAM_SIZE=5
# WHISPER_TEMPERATURE=0.0
# WHISPER_VAD_ENABLED=true
# TRANSCRIPTION_CACHE_TTL=2592000

# Chunking
# CHUNK_SIZE=512
# CHUNK_OVERLAP=64

# LLM / AI
# LLM_PROVIDER=ollama
# OLLAMA_MODEL=llama3.2:latest
# OLLAMA_BASE_URL=http://localhost:11434
# LLAMA_MODELS_DIR=
# LLAMA_CPP_N_THREADS=4
# LLAMA_CPP_N_GPU_LAYERS=0
# LLM_TEMPERATURE=0.1
# LLM_MAX_TOKENS=2048
# LLM_TOP_P=0.9
# LLM_TIMEOUT=120
# LLM_RETRY_ATTEMPTS=3
# LLM_RETRY_DELAY=2.0

# Confidence
# CONFIDENCE_THRESHOLD=0.6
# ENABLE_CONFIDENCE_SCORING=true

# Monitoring
# MONITOR_INTERVAL_SECONDS=5.0
# MONITOR_HISTORY_SIZE=360

# Caching
# CACHE_ENABLED=true
# CACHE_TTL_SECONDS=3600
# CACHE_MAX_SIZE_MB=500

# Search
# SEARCH_MAX_RESULTS=50

# Batch processing
# BATCH_SIZE=10
# BATCH_WORKERS=2
# BATCH_DELAY_SECONDS=0.5

# FFmpeg (video audio extraction)
# FFMPEG_PATH=ffmpeg
# FFMPEG_TIMEOUT=300

# Recovery / retry
# RETRY_MAX_ATTEMPTS=3
# RETRY_BASE_DELAY=1.0
# RETRY_MAX_DELAY=60.0
# RETRY_BACKOFF_FACTOR=2.0

# Deduplication
# DEDUP_HASH_ALGORITHM=sha256
# DEDUP_ENABLED=true
